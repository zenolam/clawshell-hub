{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClawShell Agent Catalog",
  "description": "Schema for standalone agent definitions available for import into any ClawShell app",
  "type": "object",
  "required": ["agents"],
  "properties": {
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agentId", "name", "description", "systemPrompt"],
        "properties": {
          "agentId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{0,62}[a-z0-9]$",
            "description": "Unique identifier for the agent"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Display name"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "Short description of what the agent does"
          },
          "systemPrompt": {
            "type": "string",
            "minLength": 1,
            "description": "Full system prompt (SOUL.md content)"
          },
          "model": {
            "type": "string",
            "description": "Default model, e.g. 'claude-sonnet-4-20250514'",
            "default": "claude-sonnet-4-20250514"
          },
          "category": {
            "type": "string",
            "enum": ["productivity", "development", "research", "analytics", "communication", "automation", "creative", "other"],
            "description": "Agent category"
          },
          "author": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    }
  }
}
