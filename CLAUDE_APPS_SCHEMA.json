{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://clawshell.dev/schemas/community-apps.json",
  "title": "ClawShell Community Apps Catalog",
  "description": "Schema for the ClawShell community apps catalog",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["appId", "name", "summary", "repo", "manifestUrl", "latestVersion"],
    "additionalProperties": false,
    "properties": {
      "appId": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$",
        "description": "Unique identifier for the app (lowercase letters, numbers, hyphens)"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100,
        "description": "Display name of the app"
      },
      "summary": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200,
        "description": "Short description of the app"
      },
      "description": {
        "type": "string",
        "maxLength": 2000,
        "description": "Full description of the app (optional)"
      },
      "repo": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+$",
        "description": "GitHub repository in owner/repo format"
      },
      "manifestUrl": {
        "type": "string",
        "format": "uri",
        "description": "URL to the app's manifest.json"
      },
      "iconUrl": {
        "type": "string",
        "format": "uri",
        "description": "URL to the app's icon (optional)"
      },
      "latestVersion": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$",
        "description": "Latest version following SemVer"
      },
      "minShellVersion": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$",
        "description": "Minimum required ClawShell version"
      },
      "categories": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["productivity", "development", "communication", "analytics", "automation", "education", "entertainment", "other"]
        },
        "description": "Categories the app belongs to"
      },
      "author": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["name"]
      }
    }
  }
}
